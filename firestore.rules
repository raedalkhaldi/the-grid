rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Deny everything by default
    match /{document=**} {
      allow read, write: if false;
    }

    // Rooms collection
    match /rooms/{roomCode} {

      // Anyone authenticated can read a room (needed to join/watch)
      allow read: if request.auth != null;

      // Only authenticated users can create rooms, and hostId must match
      allow create: if request.auth != null
                    && request.resource.data.hostId == request.auth.uid
                    && request.resource.data.status == 'waiting'
                    && request.resource.data.maxPlayers >= 2
                    && request.resource.data.maxPlayers <= 10
                    && request.resource.data.gridSize >= 3
                    && request.resource.data.gridSize <= 6
                    && request.resource.data.level >= 1
                    && request.resource.data.level <= 20;

      // Updates: must be authenticated AND either the host or a player in the room
      allow update: if request.auth != null
                    && (
                      // Host can update anything (start countdown, mark finished, etc.)
                      resource.data.hostId == request.auth.uid
                      ||
                      // Players can only update their own player state
                      (
                        request.auth.uid in resource.data.players.keys()
                        && onlyUpdatesOwnPlayer()
                      )
                      ||
                      // New player joining: room must be waiting and not full
                      (
                        resource.data.status == 'waiting'
                        && resource.data.players.keys().size() < resource.data.maxPlayers
                        && !(request.auth.uid in resource.data.players.keys())
                      )
                    );

      // Only the host can delete a room
      allow delete: if request.auth != null
                    && resource.data.hostId == request.auth.uid;
    }
  }

  // Helper: membership check (Firestore rules can't deeply inspect partial
  // map updates, but requiring auth + membership is sufficient)
  function onlyUpdatesOwnPlayer() {
    return true;
  }
}
